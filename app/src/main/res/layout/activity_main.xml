<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="12dp"
        android:paddingTop="18dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/btnLanguage"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="EN"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/chip_bg"
            android:layout_marginEnd="7dp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/btnModel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/chip_bg"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model"
                android:textSize="8sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/chip_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="7sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/separator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toBottomOf="@id/separator">

        <View
            android:id="@+id/statusDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_bg"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No model loaded - tap Model"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/statusRow">

        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/border" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <View
        android:id="@+id/separator2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        app:layout_constraintTop_toBottomOf="@id/progressContainer" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbarThumbVertical="@color/border"
        android:overScrollMode="never"
        android:fadeScrollbars="true"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:id="@+id/phrasesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap a button below to start\nMic: your voice\nPhone: what is playing on device"
                android:textSize="15sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:lineSpacingMultiplier="1.8"
                android:layout_marginTop="60dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:background="@color/bg_primary"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/btnCopy"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="C"
                android:textSize="20sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/icon_btn_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <View
                    android:id="@+id/pulseRing"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/pulse_ring"
                    android:alpha="0" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnRecord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:enabled="false"
                    android:contentDescription="Record microphone"
                    app:fabSize="normal"
                    app:backgroundTint="@color/btn_disabled"
                    app:tint="@color/text_primary"
                    app:srcCompat="@android:drawable/ic_btn_speak_now"
                    app:elevation="4dp"
                    app:maxImageSize="26dp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <View
                    android:id="@+id/pulseRingPhone"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/pulse_ring"
                    android:alpha="0" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnPhoneAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:enabled="false"
                    android:contentDescription="Capture phone audio"
                    app:fabSize="normal"
                    app:backgroundTint="@color/btn_disabled"
                    app:tint="@color/text_primary"
                    app:srcCompat="@android:drawable/ic_lock_silent_mode_off"
                    app:elevation="4dp"
                    app:maxImageSize="26dp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/btnOverlay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="CC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="@drawable/icon_btn_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Captions"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
